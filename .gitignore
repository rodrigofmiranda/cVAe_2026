# Outputs / runs (gerados)
outputs/
runs/
logs/
tables/
plots/
events.out.tfevents.*

# Datasets (large binary data) – only allow LFS-tracked content
data/*
!data/dataset_*_organized/
!data/16qam/

# Backups locais (não versionar)
backup/
*.tar
*.zip
*.rar

# Checkpoints / model weights (se estiverem fora de outputs)
*.h5
*.ckpt
*.pt
*.keras
*.weights.h5

# Python / Jupyter
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
.venvs/
*.swp

# Temporary / log files
*.tmp
*.log
.tmp_*.py
.tmp_docling_cache_md/
.bash_history

# OS
.DS_Store

# Accidental CLI artifact files (multiline paste mistakes)
--*

# Local research knowledge base artifacts
knowledge/papers/raw/*.pdf
knowledge/papers/parsed/*
!knowledge/papers/parsed/README.md
knowledge/imports/*
!knowledge/imports/README.md
knowledge/index/chroma_db/
knowledge/index/index_state.json
knowledge/index/chroma_db_*/
knowledge/index/index_state_*.json

# Local runtime/bootstrap artifacts
.pydeps/
.mplconfig/
.cache/
docs/active/.codex
