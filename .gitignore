# Outputs / runs (gerados)
outputs/
runs/
logs/
tables/
plots/
events.out.tfevents.*

# Datasets (large binary data — only LFS-tracked files are allowed)
data/
!data/dataset_fullsquare_organized/**/*.npy
!data/dataset_fullsquare_organized/**/*.json

# Backups locais (não versionar)
backup/
*.tar
*.zip

# Checkpoints / model weights (se estiverem fora de outputs)
*.h5
*.ckpt
*.pt
*.keras
*.weights.h5

# Python / Jupyter
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
*.swp

# Temporary / log files
*.tmp
*.log

# OS
.DS_Store

# Accidental CLI artifact files (multiline paste mistakes)
--*
